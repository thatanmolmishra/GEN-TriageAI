# TriageAI Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
# ============================================
GOOGLE_API_KEY=your_google_api_key_here

# ============================================
# Backend Configuration
# ============================================
PORT=8000
HOST=0.0.0.0
DEBUG=true

# Gemini Model
GEMINI_MODEL=gemini-1.5-flash

# ============================================
# Queue Configuration
# ============================================
# How often (seconds) to broadcast WebSocket updates
WS_BROADCAST_INTERVAL=3

# Seed demo patients on startup (true/false)
SEED_DEMO_PATIENTS=true

# ============================================
# Frontend (only needed for Docker build)
# ============================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/dashboard

# ============================================
# Google Cloud (only needed for deployment)
# ============================================
# GCP_PROJECT_ID=your-gcp-project-id
# GCR_HOSTNAME=gcr.io
